#################################
# Docker compose configurations #
#################################
# COMPOSE_FILE='MariaDB/docker-compose.yml,PostgreSQL/docker-compose.yml,Redis/docker-compose.yml,Psono/docker-compose.yml,Vault-Warden/docker-compose.yml,Seafile/docker-compose.yml,OnlyOffice/docker-compose.yml,Caddy-Proxy/docker-compose.yml'
COMPOSE_FILE='MariaDB/docker-compose.yml,PostgreSQL/docker-compose.yml,Redis/docker-compose.yml,Psono/docker-compose.yml,Vault-Warden/docker-compose.yml,Seafile/docker-compose.yml,OnlyOffice/docker-compose.yml,Caddy-Proxy/docker-compose.yml'
COMPOSE_PATH_SEPARATOR=','

## Images
SEAFILE_IMAGE=seafileltd/seafile-mc:13.0-latest
CADDY_IMAGE=lucaslorentz/caddy-docker-proxy:alpine
SEADOC_IMAGE=seafileltd/sdoc-server:2.0-latest
MARIA_DB_IMAGE=mariadb:latest
MEMCACHED_IMAGE=memcached:latest
VAULT_WARDEN_IMAGE=vaultwarden/server:latest
POSTGRES_IMAGE=postgres:17.9-alpine3.23
PSONO_IMAGE=psono/psono-combo:latest
REDIS_IMAGE=redis
ONLYOFFICE_IMAGE=onlyoffice/documentserver:latest
#NOTIFICATION_SERVER_IMAGE=seafileltd/notification-server:13.0-latest
#MD_IMAGE=seafileltd/seafile-md-server:13.0-latest

## Persistent Storage
BASE_STORAGE_DIR=/blk

#################################
#      Startup parameters       #
#################################
VAULT_WARDEN_SERVER_HOSTNAME=<vault.example.com>
PSONO_SERVER_HOSTNAME=<psono.example.com>
ONLYOFFICE_SERVER_HOSTNAME=<onlyoffice.example.com>
SEAFILE_SERVER_HOSTNAME=<seafile.example.com>
SERVER_PROTOCOL=https
TIME_ZONE=America/New_York
JWT_PRIVATE_KEY=<privatekey>
SITE_ROOT=/


#####################################
# Third-party service configuration #
#####################################

## Database
MARIA_DB_HOST=mariadb
MARIA_DB_PORT=3306
MARIA_ROOT_PASSWORD=<mariadb root password>

SEAFILE_DB_USER=<mariadb user login for seafile>
SEAFILE_DB_PASSWORD=<mariadb user password>
SEAFILE_DB_NAME=seafile_db
SEAFILE_CCNET_DB_NAME=ccnet_db
SEAFILE_SEAHUB_DB_NAME=seahub_db

ONLYOFFICE_DB_USER=<mariadb user login for onlyoffice>
ONLYOFFICE_DB_PASSWORD=<mariadb user password>
ONLYOFFICE_DB_NAME=onlyoffice_db

POSTGRES_USER=<postgres user login>
POSTGRES_PASSWORD=<postgres user password>
POSTGRES_DB=postgres

## Cache
# redis # or memcached
CACHE_PROVIDER=redis

### Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis1234567

### Memcached
MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211

######################################
#        Initial variables           #
# (Only valid in first-time startup) #
######################################

## Database root password, Used to create Seafile users
INIT_MARIA_ROOT_PASSWORD=<mariadb root password>

## Seafile admin user
INIT_SEAFILE_ADMIN_EMAIL=<seafile admin email>
INIT_SEAFILE_ADMIN_PASSWORD=<seafile admin password>

############################################
# Additional configurations for extensions #
############################################

## SeaDoc service
ENABLE_SEADOC=false

## Notification
ENABLE_NOTIFICATION_SERVER=false
NOTIFICATION_SERVER_URL=

## Seafile AI
ENABLE_SEAFILE_AI=false
ENABLE_FACE_RECOGNITION=false
SEAFILE_AI_LLM_TYPE=openai
SEAFILE_AI_LLM_URL=
SEAFILE_AI_LLM_KEY= # your llm key
SEAFILE_AI_LLM_MODEL=gpt-4o-mini

## Metadata server
MD_FILE_COUNT_LIMIT=100000
